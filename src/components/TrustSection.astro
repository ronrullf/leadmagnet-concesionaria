---
import type { Demo } from '../lib/types';

interface Props {
  demo: Demo;
}

const { demo } = Astro.props;

const stats: { value: string; label: string }[] = [];
if (demo.years_operating) stats.push({ value: String(demo.years_operating), label: 'años operando' });
if (demo.properties_sold) stats.push({ value: String(demo.properties_sold), label: 'inmuebles vendidos' });
if (demo.agency_city) stats.push({ value: demo.agency_city.split(',')[0], label: 'atención local' });

const show = stats.length > 0 || demo.testimonial_text;
---

{show && (
  <section class="border-y border-line bg-paper-alt">
    <div class="mx-auto max-w-[1200px] px-6 py-14">
      {stats.length > 0 && (
        <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
          {stats.map((s) => (
            <div class="rise flex flex-col items-center gap-1 text-center">
              <span class="display-tight font-display text-[2.4375rem] font-bold">{s.value}</span>
              <span class="num text-[0.75rem] uppercase tracking-[0.14em] text-ink-soft">{s.label}</span>
            </div>
          ))}
        </div>
      )}

      {demo.testimonial_text && (
        <blockquote class="rise mx-auto mt-12 max-w-[720px] text-center">
          <p class="font-display text-[1.5625rem] font-semibold leading-snug">“{demo.testimonial_text}”</p>
          {demo.testimonial_author && (
            <footer class="mt-3 text-[0.875rem] text-ink-soft">{demo.testimonial_author}</footer>
          )}
        </blockquote>
      )}
    </div>
  </section>
)}
