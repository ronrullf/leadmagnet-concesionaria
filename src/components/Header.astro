---
import { monogram } from '../lib/format';
import { waLink, genericContactMessage } from '../lib/whatsapp';
import type { Demo } from '../lib/types';

interface Props {
  demo: Demo;
}

const { demo } = Astro.props;
const base = `/${demo.slug}`;
const wa = waLink(demo.whatsapp_e164, genericContactMessage(demo.agency_name));
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-[1200px] items-center justify-between gap-4 px-6">
    <a href={base} class="flex min-w-0 items-center gap-3">
      {demo.agency_logo_url ? (
        <img src={demo.agency_logo_url} alt={demo.agency_name} class="h-9 w-auto max-w-[140px] object-contain" />
      ) : (
        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[4px] bg-accent font-display text-sm font-bold text-accent-ink">
          {monogram(demo.agency_name)}
        </span>
      )}
      <span class="hidden truncate font-display text-base font-bold sm:block">{demo.agency_name}</span>
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium md:flex" aria-label="Principal">
      <a href={base} class="hover:text-accent">Inicio</a>
      <a href={`${base}#inmuebles`} class="hover:text-accent">Inmuebles</a>
      <a href={`${base}/contacto`} class="hover:text-accent">Contacto</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 rounded-[4px] bg-accent px-4 py-2 text-sm font-semibold text-accent-ink"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.9 1.22 3.1.15.2 2.11 3.22 5.1 4.51.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35Z" />
          <path d="M12 2a10 10 0 0 0-8.65 15.02L2.05 21.6a.5.5 0 0 0 .62.61l4.68-1.27A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-2.77.75.74-2.7-.2-.31A8.2 8.2 0 1 1 12 20.2Z" />
        </svg>
        WhatsApp
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="flex h-9 w-9 items-center justify-center rounded-[4px] border border-line md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden border-t border-line bg-paper px-6 py-4 md:hidden" aria-label="Menú móvil">
    <div class="flex flex-col gap-4 text-base font-medium">
      <a href={base}>Inicio</a>
      <a href={`${base}#inmuebles`}>Inmuebles</a>
      <a href={`${base}/contacto`}>Contacto</a>
    </div>
  </nav>
</header>
