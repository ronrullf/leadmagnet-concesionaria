---
import {
  waLink,
  visitMessage,
  videoCallMessage,
  testDriveMessage,
  vehicleVideoCallMessage,
} from '../lib/whatsapp';
import type { Demo } from '../lib/types';

interface ActionItem {
  title: string;
  ref_code: string;
  price_usd: number;
  is_import?: boolean;
}

interface Props {
  demo: Demo;
  item: ActionItem;
}

const { demo, item } = Astro.props;
const isVehicle = demo.vertical === 'concesionario';

// Crítico: ambos botones apuntan al número REAL de la agencia (whatsapp_e164).
const primaryUrl = waLink(
  demo.whatsapp_e164,
  isVehicle
    ? testDriveMessage(demo.agency_name, item.title, item.ref_code, item.price_usd, item.is_import ?? false)
    : visitMessage(demo.agency_name, item.title, item.ref_code, item.price_usd)
);
const videoUrl = waLink(
  demo.whatsapp_e164,
  isVehicle
    ? vehicleVideoCallMessage(demo.agency_name, item.title, item.ref_code)
    : videoCallMessage(demo.agency_name, item.title, item.ref_code)
);

const primaryLabel = isVehicle
  ? (item.is_import ? 'Consultar por WhatsApp' : 'Agendar prueba de manejo')
  : 'Agendar visita por WhatsApp';
---

<div class="flex flex-col gap-3 sm:flex-row">
  <a
    href={primaryUrl}
    target="_blank"
    rel="noopener"
    class="flex flex-1 items-center justify-center gap-2 rounded-[4px] bg-accent px-5 py-3.5 text-center text-sm font-semibold text-accent-ink"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.9 1.22 3.1.15.2 2.11 3.22 5.1 4.51.71.31 1.27.49 1.7.63.72.23 1.37.2 1.88.12.58-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35Z" />
      <path d="M12 2a10 10 0 0 0-8.65 15.02L2.05 21.6a.5.5 0 0 0 .62.61l4.68-1.27A10 10 0 1 0 12 2Zm0 18.2a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-2.77.75.74-2.7-.2-.31A8.2 8.2 0 1 1 12 20.2Z" />
    </svg>
    {primaryLabel}
  </a>

  <a
    href={videoUrl}
    target="_blank"
    rel="noopener"
    class="flex flex-1 items-center justify-center gap-2 rounded-[4px] border-2 border-accent px-5 py-3.5 text-center text-sm font-semibold text-accent"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="2" y="6" width="14" height="12" rx="2" />
      <path d="m16 10 6-3v10l-6-3" />
    </svg>
    Coordinar videollamada
  </a>
</div>
