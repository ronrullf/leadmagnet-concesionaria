---
import PriceBcv from './PriceBcv.astro';
import type { Vehicle, BcvRate } from '../lib/types';

interface Props {
  vehicle: Vehicle;
  slug: string;
  bcv: BcvRate;
  stagger?: number;
}

const { vehicle: v, slug, bcv, stagger = 0 } = Astro.props;

const specs: string[] = [];
if (v.year) specs.push(String(v.year));
if (v.mileage_km !== null && v.mileage_km !== undefined) {
  specs.push(v.mileage_km === 0 ? '0 km' : `${new Intl.NumberFormat('es-VE').format(v.mileage_km)} km`);
}
if (v.transmission) specs.push(v.transmission === 'automatica' ? 'Automática' : v.transmission === 'sincronica' ? 'Sincrónica' : v.transmission);
if (v.fuel) specs.push(v.fuel.charAt(0).toUpperCase() + v.fuel.slice(1));
---

<a
  href={`/${slug}/vehiculo/${v.ref_code}`}
  class="property-card rise group block overflow-hidden rounded-[8px] border border-line bg-paper"
  data-property
  data-condition={v.condition}
  data-brand={v.brand ?? ''}
  data-type={v.vehicle_type ?? ''}
  data-price={v.price_usd}
  data-year={v.year ?? 0}
  data-stagger={stagger}
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={v.image_urls[0]}
      alt={v.title}
      loading="lazy"
      class="card-img h-full w-full object-cover"
    />
    <span class="num absolute left-3 top-3 rounded-[4px] bg-ink/85 px-2 py-1 text-[0.75rem] uppercase tracking-[0.12em] text-white">
      {v.condition}
    </span>
    <span class="num absolute right-3 top-3 rounded-[4px] bg-paper/90 px-2 py-1 text-[0.75rem] text-ink">
      {v.ref_code}
    </span>
    {v.is_import && (
      <span class="num absolute bottom-3 left-3 rounded-[4px] bg-accent px-2 py-1 text-[0.75rem] uppercase tracking-[0.12em] text-accent-ink">
        Importación
      </span>
    )}
  </div>

  <div class="flex flex-col gap-2.5 p-4">
    <h3 class="line-clamp-2 font-display text-[1.25rem] font-semibold leading-snug">{v.title}</h3>

    {specs.length > 0 && (
      <p class="num text-[0.875rem] text-ink-soft">{specs.join(' · ')}</p>
    )}

    {v.is_import && v.import_wait && (
      <p class="flex items-center gap-1.5 text-[0.875rem] text-ink-soft">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="shrink-0">
          <circle cx="12" cy="12" r="9" />
          <path d="M12 7v5l3 3" />
        </svg>
        Entrega en {v.import_wait}
      </p>
    )}

    <div class="border-t border-line pt-3">
      <PriceBcv priceUsd={v.price_usd} bcv={bcv} size="sm" />
    </div>
  </div>
</a>
