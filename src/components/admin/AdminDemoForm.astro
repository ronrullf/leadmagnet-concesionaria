---
import type { Demo, Property } from '../../lib/types';

interface Props {
  demo?: Demo | null;
  properties?: Property[];
}

const { demo = null, properties = [] } = Astro.props;

const initial = {
  id: demo?.id ?? null,
  demo: demo ?? null,
  properties: properties ?? [],
};

const ACCENT_SWATCHES = [
  '#0F5C4E', '#1D4ED8', '#9F1239', '#B45309', '#374151', '#065F46', '#6D28D9', '#0E7490',
];
---

<form id="demo-form" class="flex flex-col gap-8" novalidate>
  {/* ============ Identidad ============ */}
  <fieldset class="rounded-[8px] border border-line bg-paper p-6">
    <legend class="px-2 text-sm font-bold uppercase tracking-wide text-ink-soft">Identidad</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Nombre de la agencia *</span>
        <input name="agency_name" required class="rounded-[4px] border border-line px-3 py-2" placeholder="Inmobiliaria Costa Azul" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Slug (link) *</span>
        <div class="flex items-center gap-1">
          <span class="num text-[0.75rem] text-ink-soft">demo.tiendapana.com/</span>
          <input name="slug" required class="num flex-1 rounded-[4px] border border-line px-3 py-2" placeholder="costa-azul" />
        </div>
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Tagline</span>
        <input name="agency_tagline" class="rounded-[4px] border border-line px-3 py-2" placeholder="Bienes raíces en Margarita desde 2011" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Ciudad *</span>
        <input name="agency_city" required class="rounded-[4px] border border-line px-3 py-2" placeholder="Porlamar, Nueva Esparta" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Instagram (sin @)</span>
        <input name="instagram_handle" class="rounded-[4px] border border-line px-3 py-2" placeholder="costaazulve" />
      </label>
      <div class="flex flex-col gap-1">
        <span class="text-sm font-medium">Color de acento</span>
        <div class="flex flex-wrap items-center gap-2">
          {ACCENT_SWATCHES.map((c) => (
            <button
              type="button"
              data-swatch={c}
              class="h-8 w-8 rounded-[4px] border-2 border-transparent"
              style={`background:${c}`}
              aria-label={`Color ${c}`}
            ></button>
          ))}
          <input name="accent_hex" type="color" value="#0F5C4E" class="h-8 w-12 cursor-pointer rounded-[4px] border border-line" />
          <span id="accent-value" class="num text-[0.75rem] text-ink-soft">#0F5C4E</span>
        </div>
      </div>
      <div class="flex flex-col gap-1 md:col-span-2">
        <span class="text-sm font-medium">Logo (opcional — si no hay, se usa monograma)</span>
        <div class="flex items-center gap-3">
          <input type="file" id="logo-input" accept="image/*" class="text-sm" />
          <img id="logo-preview" class="hidden h-10 w-auto rounded-[4px] border border-line" alt="Logo" />
          <button type="button" id="logo-remove" class="hidden text-[0.75rem] text-red-700 underline">Quitar</button>
        </div>
      </div>
    </div>
  </fieldset>

  {/* ============ Contacto ============ */}
  <fieldset class="rounded-[8px] border border-line bg-paper p-6">
    <legend class="px-2 text-sm font-bold uppercase tracking-wide text-ink-soft">Contacto</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">WhatsApp (58 + 10 dígitos) *</span>
        <input name="whatsapp_e164" required inputmode="numeric" class="num rounded-[4px] border border-line px-3 py-2" placeholder="584141234567" maxlength="12" />
        <span id="wa-error" class="hidden text-[0.75rem] text-red-700">Debe ser 12 dígitos empezando por 58.</span>
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Email</span>
        <input name="contact_email" type="email" class="rounded-[4px] border border-line px-3 py-2" placeholder="info@agencia.com" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Dirección de oficina</span>
        <input name="office_address" class="rounded-[4px] border border-line px-3 py-2" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Búsqueda para Google Maps</span>
        <input name="maps_query" class="rounded-[4px] border border-line px-3 py-2" placeholder="C.C. Costa Azul, Porlamar, Venezuela" />
      </label>
    </div>
  </fieldset>

  {/* ============ Prueba social ============ */}
  <fieldset class="rounded-[8px] border border-line bg-paper p-6">
    <legend class="px-2 text-sm font-bold uppercase tracking-wide text-ink-soft">Prueba social (opcional)</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Años operando</span>
        <input name="years_operating" type="number" min="0" class="num rounded-[4px] border border-line px-3 py-2" />
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Inmuebles vendidos</span>
        <input name="properties_sold" type="number" min="0" class="num rounded-[4px] border border-line px-3 py-2" />
      </label>
      <label class="flex flex-col gap-1 md:col-span-2">
        <span class="text-sm font-medium">Testimonio</span>
        <textarea name="testimonial_text" rows="2" class="rounded-[4px] border border-line px-3 py-2"></textarea>
      </label>
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Autor del testimonio</span>
        <input name="testimonial_author" class="rounded-[4px] border border-line px-3 py-2" placeholder="María G., Pampatar" />
      </label>
    </div>
  </fieldset>

  {/* ============ Inmuebles ============ */}
  <fieldset class="rounded-[8px] border border-line bg-paper p-6">
    <legend class="px-2 text-sm font-bold uppercase tracking-wide text-ink-soft">Inmuebles (hasta 6)</legend>

    <div class="mb-4 flex flex-wrap items-center gap-3 rounded-[4px] bg-paper-alt p-3">
      <button
        type="button"
        id="copy-format"
        class="rounded-[4px] border border-line bg-paper px-3 py-2 text-[0.75rem] font-semibold"
      >📋 Copiar formato de datos</button>
      <p class="text-[0.75rem] text-ink-soft">
        Copia el formato, rellénalo con los datos de la casa (en notas o WhatsApp), cópialo de nuevo y usa
        <strong>Pegar datos</strong> en el inmueble para llenar todo de golpe.
      </p>
    </div>

    <div id="properties-list" class="flex flex-col gap-6"></div>
    <button
      type="button"
      id="add-property"
      class="mt-4 rounded-[4px] border border-dashed border-line px-4 py-3 text-sm font-medium text-ink-soft hover:text-ink"
    >+ Agregar inmueble</button>
  </fieldset>

  {/* ============ Control ============ */}
  <fieldset class="rounded-[8px] border border-line bg-paper p-6">
    <legend class="px-2 text-sm font-bold uppercase tracking-wide text-ink-soft">Control</legend>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      <label class="flex flex-col gap-1">
        <span class="text-sm font-medium">Modo</span>
        <select name="mode" class="rounded-[4px] border border-line px-3 py-2">
          <option value="rapido">Rápido</option>
          <option value="completo">Completo</option>
        </select>
      </label>
      <label class="flex items-center gap-2 pt-5">
        <input name="is_active" type="checkbox" checked class="h-4 w-4" />
        <span class="text-sm font-medium">Demo activo</span>
      </label>
      <label class="flex flex-col gap-1 md:col-span-3">
        <span class="text-sm font-medium">Notas internas</span>
        <textarea name="notes" rows="2" class="rounded-[4px] border border-line px-3 py-2"></textarea>
      </label>
    </div>
  </fieldset>

  <div class="flex items-center gap-4">
    <button
      type="submit"
      id="save-btn"
      class="rounded-[4px] bg-ink px-6 py-3 text-sm font-bold text-white disabled:opacity-50"
    >Guardar demo</button>
    <span id="save-status" class="text-sm text-ink-soft"></span>
  </div>

  {/* ============ Resultado ============ */}
  <div id="result-panel" class="hidden rounded-[8px] border-2 border-green-600 bg-green-50 p-6">
    <p class="mb-1 font-bold text-green-900">Demo guardado ✓</p>
    <p class="num mb-4 break-all text-sm" id="result-link"></p>
    <div class="flex flex-wrap gap-3">
      <button type="button" id="copy-link" class="rounded-[4px] bg-ink px-4 py-2.5 text-sm font-semibold text-white">Copiar link</button>
      <button type="button" id="copy-outreach" class="rounded-[4px] bg-green-700 px-4 py-2.5 text-sm font-semibold text-white">Copiar mensaje de WhatsApp</button>
      <a id="result-open" href="#" target="_blank" rel="noopener" class="rounded-[4px] border border-line bg-paper px-4 py-2.5 text-sm font-semibold">Abrir demo</a>
    </div>
  </div>
</form>

{/* Plantilla de un inmueble del repetidor */}
<template id="property-template">
  <div class="property-item rounded-[8px] border border-line bg-paper-alt p-4" data-index="">
    <div class="mb-3 flex items-center justify-between">
      <p class="text-sm font-bold">Inmueble <span data-num></span></p>
      <div class="flex items-center gap-3">
        <button type="button" data-paste class="rounded-[4px] border border-line bg-paper px-2.5 py-1.5 text-[0.75rem] font-semibold">Pegar datos</button>
        <label class="flex items-center gap-1.5 text-[0.75rem] font-medium">
          <input type="radio" name="featured_radio" data-field="is_featured" />
          Destacado
        </label>
        <button type="button" data-remove class="text-[0.75rem] font-medium text-red-700 underline">Eliminar</button>
      </div>
    </div>

    {/* Fallback si el navegador no da acceso directo al portapapeles */}
    <div data-paste-fallback class="mb-3 hidden">
      <textarea data-paste-area rows="6" placeholder="Pega aquí los datos con el formato copiado…" class="w-full rounded-[4px] border border-line px-3 py-2 text-sm"></textarea>
      <button type="button" data-paste-apply class="mt-1 rounded-[4px] bg-ink px-3 py-1.5 text-[0.75rem] font-semibold text-white">Aplicar datos</button>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <input data-field="ref_code" placeholder="Ref (ej: A-102) *" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
      <input data-field="title" placeholder="Título *" class="rounded-[4px] border border-line px-3 py-2 text-sm" />
      <select data-field="operation" class="rounded-[4px] border border-line px-3 py-2 text-sm">
        <option value="venta">Venta</option>
        <option value="alquiler">Alquiler</option>
      </select>
      <select data-field="property_type" class="rounded-[4px] border border-line px-3 py-2 text-sm">
        <option value="apartamento">Apartamento</option>
        <option value="casa">Casa</option>
        <option value="terreno">Terreno</option>
        <option value="local">Local</option>
        <option value="quinta">Quinta</option>
      </select>
      <input data-field="price_usd" type="number" min="0" placeholder="Precio USD *" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
      <input data-field="location" placeholder="Ubicación *" class="rounded-[4px] border border-line px-3 py-2 text-sm" />
      <div class="grid grid-cols-4 gap-2 md:col-span-2">
        <input data-field="bedrooms" type="number" min="0" placeholder="Hab" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
        <input data-field="bathrooms" type="number" min="0" placeholder="Baños" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
        <input data-field="parking" type="number" min="0" placeholder="Ptos" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
        <input data-field="area_m2" type="number" min="0" placeholder="m²" class="num rounded-[4px] border border-line px-3 py-2 text-sm" />
      </div>
      <textarea data-field="description" rows="2" placeholder="Descripción" class="rounded-[4px] border border-line px-3 py-2 text-sm md:col-span-2"></textarea>
      <input data-field="features" placeholder="Características separadas por coma (Piscina, Vigilancia 24h)" class="rounded-[4px] border border-line px-3 py-2 text-sm md:col-span-2" />
      <input data-field="maps_query" placeholder="Búsqueda de Google Maps del inmueble" class="rounded-[4px] border border-line px-3 py-2 text-sm md:col-span-2" />
    </div>

    {/* Uploader */}
    <div class="mt-3">
      <div
        data-dropzone
        class="flex min-h-[80px] cursor-pointer flex-wrap items-center gap-2 rounded-[4px] border-2 border-dashed border-line bg-paper p-3 text-sm text-ink-soft"
      >
        <span data-drop-hint>Arrastre fotos aquí o haga clic (máx 6, se comprimen solas)</span>
        <div data-previews class="flex flex-wrap gap-2"></div>
      </div>
      <input type="file" data-file-input accept="image/*" multiple class="hidden" />
      <p data-upload-status class="mt-1 text-[0.75rem] text-ink-soft"></p>
    </div>
  </div>
</template>

<script type="application/json" id="initial-data" set:html={JSON.stringify(initial)}></script>

<script>
  import '../../scripts/admin-form.js';
</script>
