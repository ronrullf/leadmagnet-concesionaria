---
import PriceBcv from './PriceBcv.astro';
import { verticalConfig } from '../lib/vertical';
import type { Demo, BcvRate } from '../lib/types';

interface FeaturedItem {
  ref_code: string;
  title: string;
  price_usd: number;
  image_urls: string[];
}

interface Props {
  demo: Demo;
  featured?: FeaturedItem | undefined;
  bcv: BcvRate;
}

const { demo, featured, bcv } = Astro.props;
const vc = verticalConfig(demo.vertical);

const dataBits: string[] = [];
if (demo.years_operating) dataBits.push(`${demo.years_operating} años`);
if (demo.properties_sold) dataBits.push(`${demo.properties_sold} ${vc.soldLabel}`);
dataBits.push(demo.agency_city);
---

<section class="border-b border-line">
  <div class={`mx-auto grid max-w-[1200px] grid-cols-1 items-center gap-10 px-6 py-12 md:gap-6 md:py-20 ${featured ? 'md:grid-cols-2' : ''}`}>
    <div class="flex flex-col gap-5">
      <h1 class="rise display-tight font-display text-[3.0625rem] font-bold leading-[1.05] md:text-[3.8125rem]" data-stagger="0">
        {demo.agency_name}
      </h1>
      {demo.agency_tagline && (
        <p class="rise text-[1.25rem] text-ink-soft" data-stagger="60">{demo.agency_tagline}</p>
      )}
      <p class="rise num text-[0.875rem] text-ink-soft" data-stagger="120">
        {dataBits.join(' · ')}
      </p>
      <div class="rise flex gap-3 pt-2" data-stagger="180">
        <a
          href="#catalogo"
          class="rounded-[4px] bg-accent px-5 py-3 text-sm font-semibold text-accent-ink"
        >Ver {vc.nounPlural.toLowerCase()}</a>
        <a
          href={`/${demo.slug}/contacto`}
          class="rounded-[4px] border border-line px-5 py-3 text-sm font-semibold"
        >Contacto</a>
      </div>
    </div>

    {featured && (
      <div class="rise relative md:justify-self-end" data-stagger="240">
        <a href={`/${demo.slug}/${vc.detailPath}/${featured.ref_code}`} class="block">
          <div class="aspect-[4/5] w-full max-w-[440px] overflow-hidden rounded-[8px] border border-line">
            <img
              src={featured.image_urls[0]}
              alt={featured.title}
              class="h-full w-full object-cover"
              fetchpriority="high"
            />
          </div>
          <div class="absolute bottom-4 left-4 right-4 rounded-[8px] border border-line bg-paper/95 p-4 backdrop-blur-sm md:left-auto md:right-[-16px] md:w-[280px]">
            <p class="mb-2 line-clamp-1 text-[0.875rem] font-medium">{featured.title}</p>
            <PriceBcv priceUsd={featured.price_usd} bcv={bcv} size="hero" />
          </div>
        </a>
      </div>
    )}
  </div>
</section>
