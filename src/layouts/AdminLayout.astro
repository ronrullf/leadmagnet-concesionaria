---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Admin TiendaPana</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen bg-paper-alt text-ink">
    <header class="border-b border-line bg-paper">
      <div class="mx-auto flex h-14 max-w-[1100px] items-center justify-between px-6">
        <a href="/admin" class="flex items-center gap-2 font-semibold">
          <span class="flex h-7 w-7 items-center justify-center rounded-[8px] bg-[#F97316] text-sm font-bold text-white">T</span>
          Demos · TiendaPana
        </a>
        <div class="flex items-center gap-3">
          <a
            href="/admin/nuevo"
            class="rounded-[4px] bg-[#F97316] px-4 py-2 text-sm font-semibold text-white hover:bg-[#EA580C]"
          >+ Nuevo demo</a>
          <button
            id="logout-btn"
            type="button"
            class="rounded-[4px] border border-line px-3 py-2 text-sm font-medium text-ink-soft hover:text-ink"
          >Salir</button>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-[1100px] px-6 py-8">
      <slot />
    </main>
    <script>
      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' });
        location.href = '/';
      });
    </script>
  </body>
</html>
