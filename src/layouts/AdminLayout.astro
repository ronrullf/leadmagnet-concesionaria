---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Admin TiendaPana</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen bg-paper-alt text-ink">
    <header class="border-b border-line bg-paper">
      <div class="mx-auto flex h-14 max-w-[1100px] items-center justify-between px-6">
        <a href="/admin" class="font-semibold">Demos · TiendaPana</a>
        <a
          href="/admin/nuevo"
          class="rounded-[4px] bg-ink px-4 py-2 text-sm font-semibold text-white"
        >+ Nuevo demo</a>
      </div>
    </header>
    <main class="mx-auto max-w-[1100px] px-6 py-8">
      <slot />
    </main>
  </body>
</html>
