---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listPacks } from '../../../lib/profession-packs';
import { MOODS } from '../../../lib/pro-types';
import { siteBase } from '../../../lib/site';

const packs = listPacks();
const siteUrl = siteBase(Astro.url.origin);
---

<AdminLayout title="Generar profesional">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-[1.5625rem] font-bold">Generar con IA</h1>
    <a href="/admin/pro" class="text-sm underline">← Volver</a>
  </div>

  {/* ============ Pegar datos ============ */}
  <div class="mb-5 max-w-[820px] rounded-[8px] border border-line bg-paper-alt p-4">
    <div class="flex flex-wrap items-center gap-3">
      <button type="button" id="copy-format" class="rounded-[4px] border border-line bg-paper px-3 py-2 text-[0.75rem] font-semibold">📋 Copiar formato</button>
      <button type="button" id="toggle-paste" class="rounded-[4px] border border-line bg-paper px-3 py-2 text-[0.75rem] font-semibold">📥 Pegar datos</button>
      <p class="text-[0.75rem] text-ink-soft">Copia el formato, rellénalo en tus notas o WhatsApp, y pégalo aquí para llenar todo de golpe.</p>
    </div>
    <div id="paste-box" class="mt-3 hidden">
      <textarea id="paste-area" rows="8" placeholder="Pega aquí los datos con el formato copiado…" class="fld num"></textarea>
      <button type="button" id="paste-apply" class="mt-2 rounded-[4px] bg-ink px-3 py-1.5 text-[0.75rem] font-semibold text-white">Aplicar datos al formulario</button>
      <span id="paste-status" class="ml-2 text-[0.75rem] text-ink-soft"></span>
    </div>
  </div>

  <form id="gen-form" class="grid gap-5 rounded-[8px] border border-line bg-paper p-4 sm:p-6 max-w-[820px]">
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Nombre <span class="text-red-600">*</span></span>
        <input name="pro_name" required placeholder="Dra. Mariana Rojas" class="fld" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Título</span>
        <input name="pro_title" placeholder="Dermatóloga · Caracas" class="fld" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Profesión <span class="text-red-600">*</span></span>
        <input name="profession_key" required list="prof-list" placeholder="Escribe o elige…" class="fld" autocomplete="off" />
        <datalist id="prof-list">
          {packs.map((p) => <option value={p.label} data-mood={p.default_mood}></option>)}
        </datalist>
        <span class="text-[0.75rem] text-ink-soft">Puedes escribir una profesión que no esté en la lista.</span>
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Ciudad</span>
        <input name="city" placeholder="Caracas" class="fld" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Instagram (sin @)</span>
        <input name="instagram_handle" placeholder="dramarianarojas" class="fld" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Seguidores</span>
        <input name="followers" type="number" inputmode="numeric" placeholder="9400" class="fld" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">WhatsApp E.164 <span class="text-red-600">*</span></span>
        <input name="whatsapp_e164" required placeholder="584141234567" class="fld num" />
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Mood</span>
        <select name="mood" class="fld">
          {MOODS.map((m) => <option value={m}>{m}</option>)}
        </select>
      </label>
    </div>

    <label class="grid gap-1 text-sm">
      <span class="font-medium">Bio de Instagram (textual) <span class="text-red-600">*</span></span>
      <textarea name="instagram_bio" required rows="2" placeholder="Pega la bio tal cual" class="fld"></textarea>
    </label>

    <label class="grid gap-1 text-sm">
      <span class="font-medium">Captions recientes (uno por línea, hasta 3)</span>
      <textarea name="captions" rows="4" placeholder="Un caption por línea…" class="fld"></textarea>
    </label>

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Qué vende</span>
        <textarea name="what_they_sell" rows="2" placeholder="Consulta de 40 minutos con plan escrito…" class="fld"></textarea>
      </label>
      <label class="grid gap-1 text-sm">
        <span class="font-medium">Cliente ideal</span>
        <textarea name="ideal_customer" rows="2" placeholder="Mujer de 25-45 que ya gastó en productos…" class="fld"></textarea>
      </label>
    </div>

    <label class="grid gap-1 text-sm">
      <span class="font-medium">Credenciales reales (se usan textualmente)</span>
      <textarea name="real_credentials" rows="2" placeholder="Solo lo verificable. Vacío = la IA no inventa ninguna." class="fld"></textarea>
    </label>

    <div class="flex flex-wrap items-center gap-3">
      <button type="submit" id="gen-btn" class="rounded-[4px] bg-[#F97316] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#EA580C]">
        Generar copy
      </button>
      <span id="gen-status" class="text-sm text-ink-soft"></span>
    </div>

    {/* Barra de progreso */}
    <div id="progress" class="hidden">
      <div class="mb-1 flex justify-between text-[0.75rem] text-ink-soft">
        <span id="progress-label">Preparando…</span>
        <span id="progress-pct" class="num">0%</span>
      </div>
      <div class="h-2 w-full overflow-hidden rounded-full bg-paper-alt">
        <div id="progress-bar" class="h-full w-0 rounded-full bg-[#F97316] transition-all duration-500"></div>
      </div>
      <ul id="progress-steps" class="mt-3 grid gap-1 text-[0.75rem] text-ink-soft"></ul>
    </div>
  </form>

  <div id="report" class="mt-6 hidden max-w-[820px] rounded-[8px] border border-line bg-paper p-6"></div>

  <script type="application/json" id="site-url" set:html={JSON.stringify(siteUrl)}></script>

  <style>
    .fld { border: 1px solid #DDD; border-radius: 4px; padding: 8px 10px; font: inherit; width: 100%; background: #fff; }
    .fld:focus-visible { outline: 2px solid #F97316; outline-offset: 1px; }
  </style>

  <script>
    import '../../../scripts/pro-generar.js';
  </script>
</AdminLayout>
