---
import DemoLayout from '../../../layouts/DemoLayout.astro';
import PriceBcv from '../../../components/PriceBcv.astro';
import ActionBlock from '../../../components/ActionBlock.astro';
import VehicleCard from '../../../components/VehicleCard.astro';
import { getDemoBySlug, getVehicles } from '../../../lib/demos';
import { getBcvRate } from '../../../lib/bcv';
import { notFoundResponse } from '../../../lib/not-found';

const { slug, ref } = Astro.params;
const demo = await getDemoBySlug(slug!);
if (!demo || demo.vertical !== 'concesionario') return notFoundResponse();

const [vehicles, bcv] = await Promise.all([
  getVehicles(demo.id),
  getBcvRate(),
]);

const vehicle = vehicles.find((v) => v.ref_code === ref);
if (!vehicle) return notFoundResponse();

const others = vehicles.filter((v) => v.ref_code !== ref).slice(0, 3);

const typeLabels: Record<string, string> = {
  sedan: 'Sedán',
  suv: 'SUV',
  pickup: 'Pick-up',
  hatchback: 'Hatchback',
  camioneta: 'Camioneta',
  moto: 'Moto',
  camion: 'Camión',
};

const specs: { label: string; value: string }[] = [];
if (vehicle.brand) specs.push({ label: 'Marca', value: vehicle.brand });
if (vehicle.model) specs.push({ label: 'Modelo', value: vehicle.model });
if (vehicle.year) specs.push({ label: 'Año', value: String(vehicle.year) });
specs.push({ label: 'Condición', value: vehicle.condition === 'nuevo' ? 'Nuevo' : 'Usado' });
if (vehicle.vehicle_type) specs.push({ label: 'Tipo', value: typeLabels[vehicle.vehicle_type] ?? vehicle.vehicle_type });
if (vehicle.mileage_km !== null && vehicle.mileage_km !== undefined) {
  specs.push({ label: 'Kilometraje', value: `${new Intl.NumberFormat('es-VE').format(vehicle.mileage_km)} km` });
}
if (vehicle.transmission) {
  specs.push({ label: 'Transmisión', value: vehicle.transmission === 'automatica' ? 'Automática' : vehicle.transmission === 'sincronica' ? 'Sincrónica' : vehicle.transmission });
}
if (vehicle.fuel) specs.push({ label: 'Combustible', value: vehicle.fuel.charAt(0).toUpperCase() + vehicle.fuel.slice(1) });
if (vehicle.color) specs.push({ label: 'Color', value: vehicle.color });
---

<DemoLayout
  demo={demo}
  title={`${vehicle.title} — ${demo.agency_name}`}
  description={`${vehicle.title}. ${demo.agency_city}.`}
  path={`/vehiculo/${vehicle.ref_code}`}
>
  <article class="mx-auto max-w-[1200px] px-6 py-8 md:py-12">
    {/* Galería */}
    <div id="gallery" class="grid grid-cols-1 gap-3">
      <button
        id="gallery-main"
        type="button"
        class="block aspect-[16/10] w-full cursor-zoom-in overflow-hidden rounded-[8px] border border-line"
        aria-label="Ampliar imagen"
      >
        <img src={vehicle.image_urls[0]} alt={vehicle.title} class="h-full w-full object-cover" fetchpriority="high" />
      </button>

      {vehicle.image_urls.length > 1 && (
        <div class="flex gap-2 overflow-x-auto pb-1">
          {vehicle.image_urls.map((url, i) => (
            <button
              type="button"
              data-thumb={url}
              class={`h-20 w-28 shrink-0 overflow-hidden rounded-[4px] border border-line ring-accent ${i === 0 ? 'ring-2' : ''}`}
              aria-label={`Imagen ${i + 1}`}
            >
              <img src={url} alt="" loading="lazy" class="h-full w-full object-cover" />
            </button>
          ))}
        </div>
      )}
    </div>

    {/* Lightbox */}
    <div
      id="lightbox"
      class="fixed inset-0 z-[60] hidden items-center justify-center bg-ink/95 p-4"
      role="dialog"
      aria-modal="true"
      aria-label="Galería de imágenes"
    >
      <img src={vehicle.image_urls[0]} alt={vehicle.title} class="max-h-[85vh] max-w-full rounded-[4px] object-contain" />
      <button data-lb-close type="button" class="absolute right-4 top-4 flex h-11 w-11 items-center justify-center rounded-full bg-white/10 text-white" aria-label="Cerrar">✕</button>
      <button data-lb-prev type="button" class="absolute left-2 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white" aria-label="Anterior">‹</button>
      <button data-lb-next type="button" class="absolute right-2 top-1/2 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white" aria-label="Siguiente">›</button>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_380px]">
      <div class="flex flex-col gap-8">
        <header>
          <div class="num mb-2 flex flex-wrap items-center gap-2 text-[0.75rem] uppercase tracking-[0.12em] text-ink-soft">
            <span class="rounded-[4px] bg-paper-alt px-2 py-1">{vehicle.condition}</span>
            {vehicle.is_import && (
              <span class="rounded-[4px] bg-accent px-2 py-1 text-accent-ink">Importación</span>
            )}
            <span>{vehicle.ref_code}</span>
          </div>
          <h1 class="display-tight font-display text-[1.9375rem] font-bold leading-tight md:text-[2.4375rem]">
            {vehicle.title}
          </h1>
        </header>

        {/* Aviso de importación con tiempo de espera */}
        {vehicle.is_import && vehicle.import_wait && (
          <div class="flex items-start gap-3 rounded-[8px] border border-line bg-paper-alt p-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" aria-hidden="true" class="mt-0.5 shrink-0">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v5l3 3" />
            </svg>
            <div>
              <p class="text-sm font-semibold">Vehículo por importación</p>
              <p class="num mt-0.5 text-[0.875rem] text-ink-soft">Tiempo de entrega estimado: {vehicle.import_wait}</p>
            </div>
          </div>
        )}

        {/* Specs */}
        <div class="grid grid-cols-2 gap-px overflow-hidden rounded-[8px] border border-line bg-line sm:grid-cols-3">
          {specs.map((s) => (
            <div class="flex flex-col gap-1 bg-paper p-4">
              <span class="num text-[0.75rem] uppercase tracking-[0.12em] text-ink-soft">{s.label}</span>
              <span class="num text-[1.25rem] font-medium">{s.value}</span>
            </div>
          ))}
        </div>

        {vehicle.description && (
          <div>
            <h2 class="mb-3 font-display text-[1.25rem] font-semibold">Descripción</h2>
            <p class="leading-relaxed text-ink-soft">{vehicle.description}</p>
          </div>
        )}

        {vehicle.features && vehicle.features.length > 0 && (
          <div>
            <h2 class="mb-3 font-display text-[1.25rem] font-semibold">Equipamiento</h2>
            <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2">
              {vehicle.features.map((f) => (
                <li class="flex items-center gap-2 text-[0.875rem]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5" aria-hidden="true" class="shrink-0">
                    <path d="m5 13 4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      {/* Columna derecha: precio + acción */}
      <aside class="h-fit lg:sticky lg:top-24">
        <div class="flex flex-col gap-6 rounded-[8px] border border-line bg-paper p-6">
          <PriceBcv priceUsd={vehicle.price_usd} bcv={bcv} size="lg" />
          <ActionBlock demo={demo} item={vehicle} />
          <p class="text-center text-[0.75rem] text-ink-soft">
            Atendemos de inmediato por WhatsApp
          </p>
        </div>
      </aside>
    </div>

    {/* Otros vehículos */}
    {others.length > 0 && (
      <section class="mt-16 border-t border-line pt-10">
        <h2 class="display-tight mb-8 font-display text-[1.5625rem] font-bold">Otros vehículos</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {others.map((v, i) => (
            <VehicleCard vehicle={v} slug={demo.slug} bcv={bcv} stagger={i * 40} />
          ))}
        </div>
      </section>
    )}
  </article>
</DemoLayout>
