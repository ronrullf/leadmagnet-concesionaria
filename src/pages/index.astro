---
import '../styles/global.css';
import { isAuthed } from '../lib/auth';

// Sesión activa → directo al panel de demos
if (isAuthed(Astro)) {
  return Astro.redirect('/admin');
}
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TiendaPana · Demos</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='16' fill='%23F97316'/><text x='50' y='70' font-size='55' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'>T</text></svg>" />
    <style>
      :root {
        --tp-white: #FFFFFF;
        --tp-gray-bg: #F5F6F7;
        --tp-gray-line: #E6E8EA;
        --tp-gray-text: #6B7280;
        --tp-ink: #1A1D21;
        --tp-orange: #F97316;
        --tp-orange-dark: #EA580C;
      }
      body {
        font-family: "Inter Tight", system-ui, sans-serif;
        background: var(--tp-gray-bg);
        color: var(--tp-ink);
      }
      .login-card {
        background: var(--tp-white);
        border: 1px solid var(--tp-gray-line);
        box-shadow: 0 4px 24px rgba(26, 29, 33, 0.05);
      }
      .field {
        border: 1px solid var(--tp-gray-line);
        border-radius: 6px;
        padding: 11px 14px;
        font-size: 15px;
        width: 100%;
        background: var(--tp-white);
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .field:focus {
        outline: none;
        border-color: var(--tp-orange);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.15);
      }
      .btn-orange {
        background: var(--tp-orange);
        color: #fff;
        border-radius: 6px;
        padding: 12px;
        font-weight: 600;
        font-size: 15px;
        width: 100%;
        transition: background 0.15s;
      }
      .btn-orange:hover { background: var(--tp-orange-dark); }
      .btn-orange:disabled { opacity: 0.6; }
      .check-orange { accent-color: var(--tp-orange); }
    </style>
  </head>
  <body class="flex min-h-screen items-center justify-center p-6">
    <main class="w-full max-w-[400px]">
      {/* Marca */}
      <div class="mb-8 flex flex-col items-center gap-3">
        <div class="flex h-14 w-14 items-center justify-center rounded-[14px] text-[1.75rem] font-bold text-white" style="background: var(--tp-orange);">
          T
        </div>
        <div class="text-center">
          <p class="text-[1.25rem] font-bold leading-tight">TiendaPana</p>
          <p class="text-[0.875rem]" style="color: var(--tp-gray-text);">Panel de demos</p>
        </div>
      </div>

      {/* Card de login */}
      <form id="login-form" class="login-card flex flex-col gap-4 rounded-[12px] p-8">
        <label class="flex flex-col gap-1.5">
          <span class="text-[0.875rem] font-medium">Usuario</span>
          <input name="user" type="text" autocomplete="username" required class="field" placeholder="usuario o email" />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-[0.875rem] font-medium">Contraseña</span>
          <input name="pass" type="password" autocomplete="current-password" required class="field" placeholder="••••••••" />
        </label>

        <label class="flex cursor-pointer items-center gap-2 py-1">
          <input name="remember" type="checkbox" class="check-orange h-4 w-4" />
          <span class="text-[0.875rem]" style="color: var(--tp-gray-text);">Recuérdame por 30 días</span>
        </label>

        <p id="login-error" class="hidden rounded-[6px] px-3 py-2 text-[0.875rem]" style="background: #FEF2F2; color: #B91C1C;"></p>

        <button type="submit" id="login-btn" class="btn-orange">Iniciar sesión</button>
      </form>

      <p class="mt-6 text-center text-[0.75rem]" style="color: var(--tp-gray-text);">
        Acceso interno · <a href="https://tiendapana.com" class="underline">tiendapana.com</a>
      </p>
    </main>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const btn = document.getElementById('login-btn') as HTMLButtonElement;
      const errorEl = document.getElementById('login-error') as HTMLElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.classList.add('hidden');
        btn.disabled = true;
        btn.textContent = 'Entrando…';

        try {
          const res = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              user: (form.elements.namedItem('user') as HTMLInputElement).value.trim(),
              pass: (form.elements.namedItem('pass') as HTMLInputElement).value,
              remember: (form.elements.namedItem('remember') as HTMLInputElement).checked,
            }),
          });
          const json = await res.json();
          if (res.ok && json.ok) {
            location.href = '/admin';
            return;
          }
          errorEl.textContent = json.error || 'Error al iniciar sesión.';
          errorEl.classList.remove('hidden');
        } catch {
          errorEl.textContent = 'Error de conexión. Intenta de nuevo.';
          errorEl.classList.remove('hidden');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Iniciar sesión';
        }
      });
    </script>
  </body>
</html>
